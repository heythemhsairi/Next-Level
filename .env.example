# Copy this file to .env.local and fill in real values.
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role key — server-side only, NEVER expose to the browser.
# Used by the admin "create user" flow.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Synthetic email domain for username-based login.
# Users type a username; the app appends this domain before calling Supabase Auth.
USERNAME_EMAIL_DOMAIN=areencubs.studio
